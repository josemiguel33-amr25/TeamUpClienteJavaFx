<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.teamupclienteescritorio.Controladores.PantallaPartidosControlador">
   <children>
      <TextField fx:id="titulo" layoutX="100.0" layoutY="146.0">
         <font>
            <Font name="Arial" size="18.0" />
         </font>
      </TextField>
      <CheckBox fx:id="soloVerificados" layoutX="245.0" layoutY="300.0" mnemonicParsing="false" text="Solo verificados" textFill="WHITE">
         <font>
            <Font name="Arial" size="18.0" />
         </font>
      </CheckBox>
      <TextField fx:id="precio" layoutX="100.0" layoutY="295.0" prefHeight="34.0" prefWidth="100.0">
         <font>
            <Font name="Arial" size="18.0" />
         </font>
      </TextField>
      <TextField fx:id="ubicacion" layoutX="100.0" layoutY="225.0" prefHeight="34.0" prefWidth="225.0">
         <font>
            <Font name="Arial" size="18.0" />
         </font>
      </TextField>
      <ComboBox fx:id="ciudades" layoutX="342.0" layoutY="149.0" prefHeight="26.0" prefWidth="175.0" promptText="Ciudades" />
      <Label layoutX="236.0" layoutY="38.0" text="Crear Partido" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Arial Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="138.0" layoutY="112.0" text="Título del Partido" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Arial Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="164.0" layoutY="196.0" text="Ubicacion" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Arial Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="122.0" layoutY="269.0" text="Precio" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Arial Bold" size="18.0" />
         </font>
      </Label>
      <DatePicker fx:id="fecha" layoutX="346.0" layoutY="229.0" />
      <Button fx:id="botonPartido" layoutX="255.0" layoutY="420.0" mnemonicParsing="false" onAction="#crearPartido" prefHeight="26.0" prefWidth="106.0" text="Crear">
         <font>
            <Font name="Arial Bold" size="18.0" />
         </font>
      </Button>
      <ComboBox fx:id="horas" layoutX="100.0" layoutY="345.0" prefWidth="150.0" promptText="Hora" />
      <ComboBox fx:id="minutos" layoutX="375.0" layoutY="344.0" prefWidth="150.0" promptText="Minutos" />
   </children>
</AnchorPane>
