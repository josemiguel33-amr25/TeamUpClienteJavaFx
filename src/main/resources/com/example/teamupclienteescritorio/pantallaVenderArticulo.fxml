<AnchorPane fx:id="root" prefHeight="325.0" prefWidth="434.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.teamupclienteescritorio.controladores.PantallaVenderArticuloControlador">
