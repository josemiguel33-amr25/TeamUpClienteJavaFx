<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.teamupclienteescritorio.controladores.PantallaMercadoControlador">
   <children>
      <ImageView fx:id="imagenFondo" pickOnBounds="true">
         <image>
            <Image url="@imagenes/campoFondo.png" />
         </image>
      </ImageView>
      <StackPane layoutX="824.0" layoutY="22.0" prefHeight="134.0" prefWidth="622.0">
         <children>
            <ImageView fx:id="tarjetavisita" fitHeight="134.0" fitWidth="622.0" pickOnBounds="true" preserveRatio="false" />
            <HBox alignment="CENTER_LEFT" prefHeight="134.0" prefWidth="622.0" spacing="15.0">
               <children>
                  <ImageView fx:id="imagenPerfil" fitHeight="90.0" fitWidth="90.0" pickOnBounds="true" preserveRatio="false" />
                  <ImageView fx:id="imagenRango" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true" />
                  <Region HBox.hgrow="ALWAYS" />
                  <VBox alignment="CENTER_RIGHT" spacing="5.0">
                     <children>
                        <Label fx:id="monedas" text="Monedas">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Label fx:id="reputacion" text="Reputacion">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets left="15.0" right="20.0" />
               </padding>
            </HBox>
         </children>
      </StackPane>
      <Button fx:id="misArticulos" layoutX="114.0" layoutY="182.0" mnemonicParsing="false" onAction="#verMisArticulos" prefHeight="54.0" prefWidth="274.0" text="Mis Articulos">
         <font>
            <Font name="Arial Black" size="24.0" />
         </font>
      </Button>
      <Button fx:id="botonVenderArticulo" layoutX="387.0" layoutY="182.0" mnemonicParsing="false" onAction="#abrirVentaArticulo" prefHeight="54.0" prefWidth="274.0" text="Vender Articulo">
         <font>
            <Font name="Arial Black" size="24.0" />
         </font>
      </Button>
      <Button fx:id="menuPrincipal" layoutX="661.0" layoutY="182.0" mnemonicParsing="false" onAction="#irMenuPrincipal" prefHeight="54.0" prefWidth="274.0" text="Menu Principal">
         <font>
            <Font name="Arial Black" size="24.0" />
         </font>
      </Button>
      <ScrollPane fx:id="tarjetas" layoutX="112.0" layoutY="297.0" prefHeight="528.0" prefWidth="814.0">
         <content>
            <VBox fx:id="contenedorCosmeticos" prefHeight="200.0" prefWidth="100.0" spacing="20.0" />
         </content>
      </ScrollPane>
      <ImageView fx:id="logo" fitHeight="150.0" fitWidth="200.0" layoutX="51.0" layoutY="22.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@imagenes/logo.jpg" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
