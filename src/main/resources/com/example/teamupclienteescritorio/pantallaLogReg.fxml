<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.teamupclienteescritorio.Controladores.PantallaLogRegControlador">
   <children>
      <ImageView fx:id="imagenFondo" pickOnBounds="true">
         <image>
            <Image url="@imagenes/bruno1.png" />
         </image>
         <effect>
            <ColorAdjust brightness="0.07" contrast="-0.02" hue="-0.04" saturation="0.22" />
         </effect>
      </ImageView>
      <Text fx:id="textoTeamUp" fill="WHITE" layoutX="694.0" layoutY="160.0" stroke="#302323" strokeDashOffset="5.0" strokeLineCap="BUTT" strokeMiterLimit="30.0" strokeType="OUTSIDE" strokeWidth="10.0" text="LOGO">
         <font>
            <Font name="Audiowide Regular" size="120.0" />
         </font>
         <effect>
            <ColorAdjust brightness="0.37" contrast="-0.54" hue="0.47" saturation="-0.23" />
         </effect>
      </Text>
      <Button fx:id="botonCrear" layoutX="685.0" layoutY="296.0" mnemonicParsing="false" onAction="#crearCuenta" prefHeight="118.0" prefWidth="342.0" text="Crear Cuenta">
         <font>
            <Font name="Arial Black" size="40.0" />
         </font>
      </Button>
      <Button fx:id="iniciarBoton" layoutX="664.0" layoutY="498.0" mnemonicParsing="false" onAction="#iniciarSesion" prefHeight="118.0" prefWidth="392.0" text="Iniciar Sesion">
         <font>
            <Font name="Arial Black" size="40.0" />
         </font>
      </Button>
      <Button fx:id="botonSalir" layoutX="49.0" layoutY="68.0" mnemonicParsing="false" onAction="#salir" prefHeight="118.0" prefWidth="342.0" text="Salir">
         <font>
            <Font name="Arial Black" size="40.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
