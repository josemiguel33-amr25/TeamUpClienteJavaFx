<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.teamupclienteescritorio.controladores.PantallaLogRegControlador">
   <children>
      <ImageView fx:id="imagenFondo" pickOnBounds="true">
         <image>
            <Image url="@imagenes/bruno1.png" />
         </image>
         <effect>
            <ColorAdjust brightness="0.07" contrast="-0.02" hue="-0.04" saturation="0.22" />
         </effect>
      </ImageView>
      <Button fx:id="botonCrear" layoutX="632.0" layoutY="268.0" mnemonicParsing="false" onAction="#crearCuenta" prefHeight="118.0" prefWidth="342.0" text="Crear Cuenta">
         <font>
            <Font name="Arial Black" size="40.0" />
         </font>
      </Button>
      <Button fx:id="iniciarBoton" layoutX="611.0" layoutY="481.0" mnemonicParsing="false" onAction="#iniciarSesion" prefHeight="118.0" prefWidth="392.0" text="Iniciar Sesion">
         <font>
            <Font name="Arial Black" size="40.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
