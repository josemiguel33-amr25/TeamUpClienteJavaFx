<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.teamupclienteescritorio.Controladores.PantallaPartidosPrincipalControlador">
   <children>
      <ImageView fx:id="imagenFondo" pickOnBounds="true">
         <image>
            <Image url="@imagenes/fondoUsuario.png" />
         </image>
      </ImageView>
      <StackPane layoutX="979.0" layoutY="22.0" prefHeight="134.0" prefWidth="622.0">
         <children>
            <ImageView fx:id="tarjetavisita" fitHeight="150.0" fitWidth="622.0" pickOnBounds="true" preserveRatio="true" />
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <ImageView fx:id="imagenPerfil" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                  <ImageView fx:id="imagenRango" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                  <VBox prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Label fx:id="monedas" text="Monedas">
                           <font>
                              <Font size="20.0" />
                           </font>
                           <VBox.margin>
                              <Insets top="40.0" />
                           </VBox.margin>
                        </Label>
                        <Label fx:id="reputacion" text="Reputacion">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </StackPane>
      <Button fx:id="botonMisPartidos" layoutX="114.0" layoutY="182.0" mnemonicParsing="false" onAction="#irMisPartidos" prefHeight="54.0" prefWidth="274.0" text="Mis Partidos">
         <font>
            <Font name="Arial Black" size="24.0" />
         </font>
      </Button>
      <Button fx:id="botonCrearPartido" layoutX="387.0" layoutY="182.0" mnemonicParsing="false" onAction="#irCrearPartido" prefHeight="54.0" prefWidth="274.0" text="Crear Partido">
         <font>
            <Font name="Arial Black" size="24.0" />
         </font>
      </Button>
      <Button fx:id="menuPrincipal" layoutX="661.0" layoutY="182.0" mnemonicParsing="false" onAction="#irMenuPrincipal" prefHeight="54.0" prefWidth="274.0" text="Menu Principal">
         <font>
            <Font name="Arial Black" size="24.0" />
         </font>
      </Button>
      <ComboBox fx:id="ciudades" layoutX="640.0" layoutY="254.0" prefHeight="50.0" prefWidth="206.0" promptText="Ciudades" />
      <CheckBox fx:id="soloVerificados" layoutX="432.0" layoutY="264.0" mnemonicParsing="false" text="Solo Verificados">
         <font>
            <Font name="Arial" size="18.0" />
         </font>
      </CheckBox>
      <Button fx:id="recargarBoton" layoutX="289.0" layoutY="256.0" mnemonicParsing="false" onAction="#verPartidos" text="Recargar">
         <font>
            <Font name="Arial" size="20.0" />
         </font>
      </Button>
      <ScrollPane fx:id="tarjetas" layoutX="112.0" layoutY="323.0" prefHeight="528.0" prefWidth="814.0">
         <content>
            <VBox fx:id="contenedorPartidos" prefHeight="200.0" prefWidth="100.0" spacing="20.0" />
         </content>
      </ScrollPane>
      <ImageView fx:id="logo" fitHeight="150.0" fitWidth="200.0" layoutX="51.0" layoutY="22.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@imagenes/logo.jpg" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
